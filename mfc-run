#!/usr/bin/env bash
# mfc-run — Run an MFC simulation with automatic archiving
#
# Usage:
#   mfc-run <case_path> [mfc_flags...]
#   mfc-run --list-runs <case_name>
#   mfc-run --archive-only <case_path> [mfc_flags...]   # archive existing output without running
#   mfc-run --help
set -euo pipefail

# ─── Configuration ──────────────────────────────────────────────────────────
MFC_ROOT="${MFC_ROOT:-}"
: "${ARCHIVE_BASE:="${HOME}/.local/share/mfc/runs"}"

# Directories to move (large, generated output)
MOVE_DIRS=(D silo_hdf5 restart_data p_all)

# Files to move (generated by MFC, not needed locally after archive)
MOVE_FILE_PATTERNS=(
    "MFC.sh"
    "run_time.inf"
    "pre_process.inp"
    "simulation.inp"
    "post_process.inp"
    "syscheck.inp"
    "indices.dat"
    "equations.dat"
    "time_data.dat"
    "io_time_data.dat"
    "pre_time_data.dat"
    "fort.1"
    "MFC.out"
)

# Directories/patterns to skip entirely (never archive)
SKIP_DIRS=(.venv __pycache__ .ipynb_checkpoints runs)

# ─── Colors ─────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
    BOLD=$'\033[1m'
    GREEN=$'\033[32m'
    RED=$'\033[31m'
    YELLOW=$'\033[33m'
    CYAN=$'\033[36m'
    DIM=$'\033[2m'
    RESET=$'\033[0m'
else
    BOLD="" GREEN="" RED="" YELLOW="" CYAN="" DIM="" RESET=""
fi

info()    { echo -e "${BOLD}[mfc-run]${RESET} $*"; }
warn()    { echo -e "${YELLOW}[mfc-run] WARNING:${RESET} $*"; }
error()   { echo -e "${RED}[mfc-run] ERROR:${RESET} $*" >&2; }
success() { echo -e "${GREEN}[mfc-run]${RESET} $*"; }

# ─── Global state ───────────────────────────────────────────────────────────
CASE_PATH=""
CASE_DIR=""
CASE_NAME=""
MFC_FLAGS=()
TIMESTAMP=""
RUN_DESCRIPTION=""
CASE_JSON=""
CASE_SHA256=""
MFC_EXIT_CODE=0
MFC_PID=""
RUN_STATUS="SUCCESS"
START_TIME=0
END_TIME=0
ARCHIVE_ONLY=false
ARCHIVE_DIR=""

# ─── Config file loading ───────────────────────────────────────────────────
load_config() {
    local config_file="${XDG_CONFIG_HOME:-${HOME}/.config}/mfc/run.conf"
    [[ -f "$config_file" ]] || return 0

    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip blank lines and comments
        [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
        # Strip inline comments and surrounding whitespace
        line="${line%%#*}"
        line="$(echo "$line" | xargs)"
        [[ -z "$line" ]] && continue

        local key="${line%%=*}"
        local val="${line#*=}"
        # Remove surrounding quotes from value
        val="${val#\"}" ; val="${val%\"}"
        val="${val#\'}" ; val="${val%\'}"

        case "$key" in
            MFC_ROOT)
                # Only use config value if env var is not already set
                [[ -z "${MFC_ROOT:-}" ]] && MFC_ROOT="$val"
                ;;
            ARCHIVE_BASE)
                # Only override if the user hasn't set the env var
                # (we already set a default above, so check if env was explicitly set)
                if [[ "${ARCHIVE_BASE}" == "${HOME}/.local/share/mfc/runs" ]]; then
                    ARCHIVE_BASE="$val"
                fi
                ;;
            *)
                warn "Unknown config key in ${config_file}: ${key}"
                ;;
        esac
    done < "$config_file"
}

# ─── Auto-detect MFC root ──────────────────────────────────────────────────
detect_mfc_root() {
    # If MFC_ROOT is already set and valid, nothing to do
    [[ -n "${MFC_ROOT:-}" && -f "${MFC_ROOT}/mfc.sh" ]] && return 0

    # Walk up from CASE_DIR, then cwd, looking for mfc.sh + toolchain/util.sh
    for start in "${CASE_DIR:-}" "$(pwd)"; do
        [[ -z "$start" ]] && continue
        local dir="$start"
        while [[ "$dir" != "/" ]]; do
            if [[ -f "${dir}/mfc.sh" && -f "${dir}/toolchain/util.sh" ]]; then
                MFC_ROOT="$dir"
                return 0
            fi
            dir="$(dirname "$dir")"
        done
    done

    error "Cannot find MFC root. Set MFC_ROOT or run from within the MFC tree."
    exit 1
}

# ─── Usage ──────────────────────────────────────────────────────────────────
usage() {
    cat <<EOF
Usage:
  mfc-run <case_path> [mfc_flags...]        Run simulation and archive results
  mfc-run --archive-only <case_path> [flags...]  Archive existing output (skip mfc.sh)
  mfc-run --list-runs <case_name>           List archived runs for a case
  mfc-run --help                            Show this help

Arguments:
  case_path     Path to case.py (or its parent directory)
  mfc_flags     All remaining flags are passed through to ./mfc.sh run

Examples:
  mfc-run examples/2D_recovering_ellipse/case.py -n 24 --gpu --clean
  mfc-run examples/2D_recovering_ellipse -n 2 --clean
  mfc-run --archive-only examples/2D_recovering_ellipse/case.py
  mfc-run --list-runs 2D_recovering_ellipse

Archive destination:
  Success: \${ARCHIVE_BASE}/<case_name>/runs/<YYYY-MM-DD_HHMMSS_description>/
  Failed:  \${ARCHIVE_BASE}/<case_name>/failed/<YYYY-MM-DD_HHMMSS_description>/

Configuration:
  Environment variables (highest precedence):
    MFC_ROOT       Path to MFC repository (auto-detected if unset)
    ARCHIVE_BASE   Root directory for archived runs (default: ~/.local/share/mfc/runs)

  Config file: ~/.config/mfc/run.conf
    MFC_ROOT=/path/to/MFC
    ARCHIVE_BASE=/path/to/archive

  Precedence: env vars > config file > auto-detect/defaults
EOF
}

# ─── List runs ──────────────────────────────────────────────────────────────
_list_dir_runs() {
    local label="$1"
    local dir="$2"
    local found=false

    [[ -d "$dir" ]] || return 1

    for run_dir in "$dir"/*/; do
        [[ -d "$run_dir" ]] || continue
        local dirname
        dirname="$(basename "$run_dir")"
        [[ "$dirname" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{4,6} ]] || continue
        local info_file="${run_dir}run_info.json"
        if [[ -f "$info_file" ]]; then
            found=true
            python3 -c "
import json, sys
with open(sys.argv[1]) as f:
    d = json.load(f)
ts = d.get('timestamp', '?')
status = d.get('status', '?')
desc = d.get('description', '')
dur = d.get('duration_seconds', 0)
if dur > 0:
    h, m = dur // 3600, (dur % 3600) // 60
    dur_s = f'{h}h {m:02d}m'
else:
    dur_s = '  —  '
color = '\033[32m' if status == 'SUCCESS' else '\033[31m' if status == 'FAILED' else '\033[33m'
reset = '\033[0m'
print(f'  {ts}  {color}{status:<12}{reset} {dur_s:>8}  \"{desc}\"')
" "$info_file"
        else
            found=true
            echo "  ${dirname}  ${DIM}(no metadata)${RESET}"
        fi
    done

    $found && return 0 || return 1
}

list_runs() {
    local case_name="$1"
    local runs_dir="${ARCHIVE_BASE}/${case_name}/runs"
    local failed_dir="${ARCHIVE_BASE}/${case_name}/failed"

    if [[ ! -d "$runs_dir" && ! -d "$failed_dir" ]]; then
        error "No runs found for: $case_name"
        exit 1
    fi

    local any_found=false

    echo ""
    echo "${BOLD}Successful runs for ${case_name}:${RESET}"
    echo "────────────────────────────────────────────────────────────────────"
    if _list_dir_runs "runs" "$runs_dir"; then
        any_found=true
    else
        echo "  ${DIM}None.${RESET}"
    fi
    echo "────────────────────────────────────────────────────────────────────"

    echo ""
    echo "${BOLD}Failed runs for ${case_name}:${RESET}"
    echo "────────────────────────────────────────────────────────────────────"
    if _list_dir_runs "failed" "$failed_dir"; then
        any_found=true
    else
        echo "  ${DIM}None.${RESET}"
    fi
    echo "────────────────────────────────────────────────────────────────────"
    echo ""
}

# ─── Parse arguments ────────────────────────────────────────────────────────
parse_args() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    case "$1" in
        --help|-h)
            usage
            exit 0
            ;;
        --list-runs)
            if [[ $# -lt 2 ]]; then
                error "Usage: mfc-run --list-runs <case_name>"
                exit 1
            fi
            list_runs "$2"
            exit 0
            ;;
        --archive-only)
            ARCHIVE_ONLY=true
            shift
            ;;
    esac

    if [[ $# -eq 0 ]]; then
        error "No case path provided."
        usage
        exit 1
    fi

    # First positional arg is the case path
    local raw_path="$1"
    shift
    MFC_FLAGS=("$@")

    # Resolve case path: accept directory or case.py file
    if [[ -d "$raw_path" ]]; then
        raw_path="${raw_path%/}/case.py"
    fi

    # Make path absolute
    if [[ "$raw_path" != /* ]]; then
        # If relative, try from MFC_ROOT first (common pattern)
        if [[ -n "${MFC_ROOT:-}" && -f "${MFC_ROOT}/${raw_path}" ]]; then
            raw_path="${MFC_ROOT}/${raw_path}"
        else
            raw_path="$(pwd)/${raw_path}"
        fi
    fi

    CASE_PATH="$(realpath "$raw_path" 2>/dev/null || echo "$raw_path")"
    CASE_DIR="$(dirname "$CASE_PATH")"
    CASE_NAME="$(basename "$CASE_DIR")"
    TIMESTAMP="$(date +%Y-%m-%d_%H%M%S)"
}

# ─── Validate environment ──────────────────────────────────────────────────
validate_environment() {
    # Auto-detect MFC root
    detect_mfc_root

    # Check MFC root is valid
    if [[ ! -f "${MFC_ROOT}/toolchain/util.sh" ]]; then
        error "MFC root not found at ${MFC_ROOT}"
        exit 1
    fi

    # Check case.py exists
    if [[ ! -f "$CASE_PATH" ]]; then
        error "Case file not found: ${CASE_PATH}"
        exit 1
    fi

    # Check rsync
    if ! command -v rsync &>/dev/null; then
        error "rsync is required but not installed."
        exit 1
    fi

    # Ensure archive directories exist and are writable
    mkdir -p "${ARCHIVE_BASE}/${CASE_NAME}/runs" "${ARCHIVE_BASE}/${CASE_NAME}/failed"
    if [[ ! -w "${ARCHIVE_BASE}" ]]; then
        error "Archive directory is not writable: ${ARCHIVE_BASE}"
        exit 1
    fi
}

# ─── Prompt for description ────────────────────────────────────────────────
prompt_description() {
    echo ""
    echo "═══════════════════════════════════════════════════════════════"
    echo "  ${BOLD}MFC Run: ${CYAN}${CASE_NAME}${RESET}"
    echo "  ${DIM}Command: ./mfc.sh run ${CASE_PATH} ${MFC_FLAGS[*]:-}${RESET}"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
    read -rp "  Enter a short description for this run: " RUN_DESCRIPTION
    RUN_DESCRIPTION="${RUN_DESCRIPTION:-(no description)}"
    echo ""
}

# ─── Snapshot case parameters ──────────────────────────────────────────────
snapshot_case_params() {
    # SHA-256 of case.py
    CASE_SHA256="$(sha256sum "$CASE_PATH" | cut -d' ' -f1)"

    # Capture JSON parameter dump (same mechanism MFC uses)
    CASE_JSON="$(python3 "$CASE_PATH" 2>/dev/null || echo '{}')"
    if [[ "$CASE_JSON" == '{}' ]]; then
        warn "Could not capture JSON from case.py (may have errors)."
    fi
}

# ─── Run simulation ────────────────────────────────────────────────────────
handle_interrupt() {
    echo ""
    if [[ -n "$MFC_PID" ]]; then
        warn "Interrupted. Sending SIGTERM to MFC (PID $MFC_PID)..."
        kill -TERM "$MFC_PID" 2>/dev/null || true
        wait "$MFC_PID" 2>/dev/null || true
        MFC_EXIT_CODE=$?
        MFC_PID=""
    fi
    END_TIME=$(date +%s)
    RUN_STATUS="INTERRUPTED"
    archive_results
    exit 130
}

run_simulation() {
    if $ARCHIVE_ONLY; then
        info "Archive only — skipping ./mfc.sh run"
        RUN_STATUS="ARCHIVE_ONLY"
        return 0
    fi

    START_TIME=$(date +%s)

    trap 'handle_interrupt' INT TERM

    info "Starting MFC simulation..."
    echo ""

    cd "$MFC_ROOT"
    set +e
    ./mfc.sh run "$CASE_PATH" "${MFC_FLAGS[@]}" &
    MFC_PID=$!
    wait $MFC_PID
    MFC_EXIT_CODE=$?
    MFC_PID=""
    set -e

    END_TIME=$(date +%s)

    trap - INT TERM

    echo ""
    if [[ $MFC_EXIT_CODE -eq 0 ]]; then
        RUN_STATUS="SUCCESS"
        success "Simulation completed successfully."
    else
        RUN_STATUS="FAILED"
        warn "Simulation exited with code ${MFC_EXIT_CODE}."
    fi
}

# ─── Archive a single directory via rsync ───────────────────────────────────
archive_directory() {
    local dir_name="$1"
    local src="${CASE_DIR}/${dir_name}"
    local dst="${ARCHIVE_DIR}/${dir_name}"

    if [[ ! -d "$src" ]]; then
        return 0
    fi

    # Check if directory has content
    if [[ -z "$(ls -A "$src" 2>/dev/null)" ]]; then
        info "  Skipping empty: ${dir_name}/"
        return 0
    fi

    local size
    size="$(du -sh "$src" 2>/dev/null | cut -f1)"
    info "  Moving ${dir_name}/ (${size})..."

    mkdir -p "$dst"
    rsync -a --remove-source-files "$src/" "$dst/"
    local rc=$?

    if [[ $rc -eq 0 ]]; then
        # Remove the now-empty source directory tree
        find "$src" -type d -empty -delete 2>/dev/null || true
        success "  Done: ${dir_name}/"
    else
        warn "  rsync failed for ${dir_name}/ (exit ${rc}). Files may remain locally."
    fi

    return $rc
}

# ─── Write run metadata ────────────────────────────────────────────────────
write_metadata() {
    local metadata_path="$1"
    local duration=0
    if [[ $END_TIME -gt 0 && $START_TIME -gt 0 ]]; then
        duration=$((END_TIME - START_TIME))
    fi

    local mfc_git_hash
    mfc_git_hash="$(git -C "$MFC_ROOT" rev-parse --short HEAD 2>/dev/null || echo 'unknown')"

    local flags_json
    flags_json="$(printf '%s\n' "${MFC_FLAGS[@]}" 2>/dev/null | python3 -c 'import json,sys; print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))' 2>/dev/null || echo '[]')"

    python3 -c "
import json, os, sys

data = {
    'version': 1,
    'case_name': sys.argv[1],
    'timestamp': sys.argv[2],
    'description': sys.argv[3],
    'status': sys.argv[4],
    'exit_code': int(sys.argv[5]),
    'duration_seconds': int(sys.argv[6]),
    'command': './mfc.sh run ' + sys.argv[7] + ' ' + ' '.join(json.loads(sys.argv[8])),
    'mfc_flags': json.loads(sys.argv[8]),
    'case_py_sha256': sys.argv[9],
    'mfc_git_hash': sys.argv[10],
    'hostname': os.uname().nodename,
}

# Include key simulation parameters if available
try:
    params = json.loads(sys.argv[11])
    keys = ['m', 'n', 'p', 'dt', 't_step_start', 't_step_stop', 't_step_save',
            'num_fluids', 'sigma', 'weno_order', 'model_eqns', 'num_patches']
    data['parameters'] = {k: params[k] for k in keys if k in params}
except:
    data['parameters'] = {}

with open(sys.argv[12], 'w') as f:
    json.dump(data, f, indent=2)
    f.write('\n')
" "$CASE_NAME" "$TIMESTAMP" "$RUN_DESCRIPTION" "$RUN_STATUS" \
  "$MFC_EXIT_CODE" "$duration" "$CASE_PATH" "$flags_json" \
  "$CASE_SHA256" "$mfc_git_hash" "$CASE_JSON" "$metadata_path"
}

# ─── Archive results ───────────────────────────────────────────────────────
archive_results() {
    # Sanitize description for use in directory name (lowercase, replace spaces/special chars)
    local slug=""
    if [[ -n "$RUN_DESCRIPTION" && "$RUN_DESCRIPTION" != "(no description)" ]]; then
        slug=$(echo "$RUN_DESCRIPTION" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | sed 's/^-//;s/-$//' | cut -c1-50)
    fi
    local dir_name="${TIMESTAMP}"
    [[ -n "$slug" ]] && dir_name="${TIMESTAMP}_${slug}"

    # Separate successful and failed/interrupted runs
    if [[ "$RUN_STATUS" == "SUCCESS" || "$RUN_STATUS" == "ARCHIVE_ONLY" ]]; then
        ARCHIVE_DIR="${ARCHIVE_BASE}/${CASE_NAME}/runs/${dir_name}"
    else
        ARCHIVE_DIR="${ARCHIVE_BASE}/${CASE_NAME}/failed/${dir_name}"
    fi

    # Handle timestamp collision
    if [[ -d "$ARCHIVE_DIR" ]]; then
        local suffix=1
        while [[ -d "${ARCHIVE_DIR}_${suffix}" ]]; do
            ((suffix++))
        done
        ARCHIVE_DIR="${ARCHIVE_DIR}_${suffix}"
    fi

    mkdir -p "$ARCHIVE_DIR"
    info "Archiving to: ${ARCHIVE_DIR}"
    echo ""

    # 1. Write metadata
    write_metadata "${ARCHIVE_DIR}/run_info.json"
    info "  Wrote run_info.json"

    # 2. Save case.py snapshot and JSON params
    cp "$CASE_PATH" "${ARCHIVE_DIR}/case.py"
    if [[ "$CASE_JSON" != '{}' && -n "$CASE_JSON" ]]; then
        echo "$CASE_JSON" | python3 -m json.tool > "${ARCHIVE_DIR}/case_params.json" 2>/dev/null || \
            echo "$CASE_JSON" > "${ARCHIVE_DIR}/case_params.json"
    fi
    info "  Saved case.py + case_params.json"

    # 3. Move large output directories
    for dir_name in "${MOVE_DIRS[@]}"; do
        archive_directory "$dir_name"
    done

    # 4. Move generated files
    for pattern in "${MOVE_FILE_PATTERNS[@]}"; do
        local src="${CASE_DIR}/${pattern}"
        if [[ -f "$src" ]]; then
            mv "$src" "${ARCHIVE_DIR}/"
        fi
    done
    info "  Moved generated files"

    # 5. Copy source/analysis files (keep locally)
    mkdir -p "${ARCHIVE_DIR}/postproc"
    local copied=()
    for ext in py ipynb png; do
        for f in "${CASE_DIR}"/*.${ext}; do
            [[ -f "$f" ]] || continue
            local fname
            fname="$(basename "$f")"
            # case.py already copied above
            [[ "$fname" == "case.py" ]] && continue
            cp "$f" "${ARCHIVE_DIR}/postproc/"
            copied+=("$fname")
        done
    done
    if [[ ${#copied[@]} -gt 0 ]]; then
        info "  Copied to postproc/: ${copied[*]}"
    fi

    echo ""
    print_summary
}

# ─── Print summary ─────────────────────────────────────────────────────────
print_summary() {
    local duration=0
    if [[ $END_TIME -gt 0 && $START_TIME -gt 0 ]]; then
        duration=$((END_TIME - START_TIME))
    fi
    local h=$((duration / 3600))
    local m=$(( (duration % 3600) / 60 ))
    local s=$((duration % 60))

    local status_color="$GREEN"
    [[ "$RUN_STATUS" == "FAILED" ]] && status_color="$RED"
    [[ "$RUN_STATUS" == "INTERRUPTED" ]] && status_color="$YELLOW"
    [[ "$RUN_STATUS" == "ARCHIVE_ONLY" ]] && status_color="$CYAN"

    echo "═══════════════════════════════════════════════════════════════"
    echo "  ${BOLD}mfc-run complete${RESET}"
    echo "═══════════════════════════════════════════════════════════════"
    echo "  Case:        ${CYAN}${CASE_NAME}${RESET}"
    echo "  Status:      ${status_color}${RUN_STATUS}${RESET} (exit code ${MFC_EXIT_CODE})"
    echo "  Description: ${RUN_DESCRIPTION}"
    if [[ $duration -gt 0 ]]; then
        echo "  Duration:    ${h}h ${m}m ${s}s"
    fi
    echo "  Archive:     ${ARCHIVE_DIR:-N/A}"
    echo "═══════════════════════════════════════════════════════════════"
    echo ""
}

# ─── Main ───────────────────────────────────────────────────────────────────
main() {
    load_config
    parse_args "$@"
    validate_environment
    prompt_description
    snapshot_case_params
    run_simulation
    archive_results
}

main "$@"
